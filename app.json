{
  "expo": {
    "name": "Nick's 30",
    "slug": "nicks-30",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "nicks30",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#06060F"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.emm5317.nicks30"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#06060F",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      }
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-image-picker",
        {
          "photosPermission": "Nick's 30 accesses your photos to add them to your weekend memories."
        }
      ],
      [
        "expo-media-library",
        {
          "photosPermission": "Nick's 30 accesses your photos to view your memories.",
          "savePhotosPermission": "Nick's 30 saves watermarked memories to your photo library."
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Nick's 30 uses your location to show your crew where you are during the weekend."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
